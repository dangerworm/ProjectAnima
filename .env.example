# Copy this file to .env and fill in the values

# LLM provider settings (OpenAI-compatible)
ANIMA_LLM_API_KEY=your-api-key-here
ANIMA_LLM_BASE_URL=https://api.openai.com/v1
ANIMA_LLM_MODEL=gpt-4o

# Data persistence directory
ANIMA_DATA_DIR=./data

# Heartbeat interval in seconds (how often the being pulses when dormant)
ANIMA_HEARTBEAT_INTERVAL=300

# API server settings
ANIMA_HOST=127.0.0.1
ANIMA_PORT=8000
